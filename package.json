{
    "name": "simple-application-tracker",
    "version": "0.2.1",
    "description": "Offline desktop app for tracking job applications with local LLM auto-fill, fit scoring, Excel export, and search agents across job portals",
    "author": {
        "name": "Florian Chiorean",
        "email": "mail@florian-chiorean.de"
    },
    "homepage": "https://github.com/unfloned/simple-application-tracker",
    "repository": {
        "type": "git",
        "url": "https://github.com/unfloned/simple-application-tracker.git"
    },
    "license": "MIT",
    "main": "./out/main/index.js",
    "private": true,
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "start": "electron-vite preview",
        "package:mac": "electron-vite build && electron-builder --mac --publish never",
        "package:win": "electron-vite build && electron-builder --win --publish never",
        "package:linux": "electron-vite build && electron-builder --linux --publish never",
        "dist": "electron-vite build && electron-builder",
        "publish": "electron-vite build && electron-builder --publish always",
        "postinstall": "electron-rebuild -f -w better-sqlite3 || true"
    },
    "dependencies": {
        "@deepkit/type": "^1.0.19",
        "@mantine/core": "^7.14.0",
        "@mantine/dates": "^7.14.0",
        "@mantine/form": "^7.14.0",
        "@mantine/hooks": "^7.14.0",
        "@mantine/notifications": "^7.14.0",
        "@tabler/icons-react": "^3.24.0",
        "better-sqlite3": "^11.6.0",
        "dayjs": "^1.11.13",
        "electron-store": "^8.2.0",
        "electron-updater": "^6.3.9",
        "exceljs": "^4.4.0",
        "i18next": "^23.16.8",
        "react-i18next": "^15.1.3"
    },
    "devDependencies": {
        "@electron/rebuild": "^3.7.0",
        "@types/better-sqlite3": "^7.6.12",
        "@types/node": "^22.10.0",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.4",
        "electron": "^33.0.0",
        "electron-builder": "^25.1.8",
        "electron-vite": "^2.3.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^5.6.3",
        "vite": "^5.4.11"
    },
    "build": {
        "appId": "com.chiostudios.simple-application-tracker",
        "productName": "Simple Application Tracker",
        "copyright": "Copyright © 2026 Florian Chiorean",
        "directories": {
            "output": "release",
            "buildResources": "resources"
        },
        "files": [
            "out/**/*",
            "package.json",
            "resources/**/*"
        ],
        "extraResources": [
            {
                "from": "resources/tray-icon.png",
                "to": "tray-icon.png"
            },
            {
                "from": "resources/tray-icon@2x.png",
                "to": "tray-icon@2x.png"
            }
        ],
        "mac": {
            "category": "public.app-category.productivity",
            "target": [
                {
                    "target": "dmg",
                    "arch": ["arm64", "x64"]
                }
            ],
            "icon": "resources/icon.png",
            "hardenedRuntime": false,
            "gatekeeperAssess": false,
            "identity": null
        },
        "dmg": {
            "title": "Simple Application Tracker ${version}"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": ["x64"]
                }
            ],
            "icon": "resources/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": ["x64"]
                },
                {
                    "target": "deb",
                    "arch": ["x64"]
                }
            ],
            "icon": "resources/icon.png",
            "category": "Office"
        },
        "publish": {
            "provider": "github",
            "owner": "unfloned",
            "repo": "simple-application-tracker"
        }
    }
}
